{
  "installCommand": "npm ci",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.agentstack.fyi" }],
      "destination": "https://agentstack.fyi/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/((?!api/|crawl/|assets/)(?!llms\\.txt$)(?!robots\\.txt$).*)",
      "destination": "/index.html"
    }
  ]
}
