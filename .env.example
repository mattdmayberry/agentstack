# From hosted project: Settings → API (or run `npm run supabase:status` after local start)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: secret path for admin UI on admin.* host only (default: admin). Example: stack-ops-7f3a or internal/panel
VITE_ADMIN_ROUTE=

# Local Supabase (after `npm run supabase:start`, copy values from command output or `supabase status`):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key from supabase status>
