# From hosted project: Settings → API (or run `npm run supabase:status` after local start)
VITE_SUPABASE_URL=
# Used by the browser app and by the Vercel Edge handler `api/sitemap.ts` (sitemap.xml) — set in Production/Preview on Vercel.
VITE_SUPABASE_ANON_KEY=
# Optional: path segment(s) for admin UI — no leading slash (default: admin). Example: agent-ops-704 or internal/panel (letters, digits, hyphens; use / for nested paths)
VITE_ADMIN_ROUTE=
# Optional: allow admin on the main site host(s) without an admin subdomain — comma-separated hostnames only, e.g. agentstack.fyi,www.agentstack.fyi (prefer Production-only on Vercel; omit on Preview if you use *.vercel.app)
# VITE_ADMIN_EXTRA_HOSTS=

# Local Supabase (after `npm run supabase:start`, copy values from command output or `supabase status`):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key from supabase status>

# Optional: full origin for "open admin here" links when someone hits the admin path on the wrong host.
# Example: https://admin.agentstack.fyi — omit path; defaults to https://admin.<your-current-apex>.
# VITE_PUBLIC_ADMIN_ORIGIN=

# Vercel: Project → Settings → Environment Variables (Production + Preview).
# Use your hosted Supabase URL + anon key, not localhost.

# --- Local dev: empty feed? ---
# Quickest: temporarily set VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY to your *hosted* (production)
# Supabase values — the app only reads what RLS allows (approved articles for anon). No script required.
#
# To copy articles *into* local Supabase instead, run `npm run supabase:start`, apply migrations, then:
#   export SYNC_SOURCE_SUPABASE_URL="https://<prod>.supabase.co"
#   export SYNC_SOURCE_SUPABASE_KEY="<prod anon or service_role>"
#   export SYNC_TARGET_SUPABASE_URL="http://127.0.0.1:54321"
#   export SYNC_TARGET_SUPABASE_SERVICE_ROLE="<service_role from supabase status>"
#   export SYNC_CLEAR_LOCAL=1   # optional: delete local articles first
#   npm run sync:articles-from-remote
#
# Dev-only: `npm run dev` auto-shows sample articles when Supabase returns zero approved rows (so the UI is not blank).
# Set to see the full empty-state / setup checklist instead:
# VITE_DEV_STRICT_EMPTY_FEED=1
